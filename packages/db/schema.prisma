generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  studyLogs      StudyLog[]
  aiInteractions AIInteraction[]
  settings       UserSettings?
}

model StudyLog {
  id          String    @id @default(cuid())
  userId      String
  skill       SkillType
  durationMin Int       @map("duration_min")
  note        String?
  logDate     DateTime  @map("log_date") @db.Date
  focusLevel  Int?      @map("focus_level")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, logDate])
  @@map("study_logs")
}

model AIInteraction {
  id           String          @id @default(cuid())
  userId       String
  type         InteractionType
  inputText    String          @map("input_text")
  responseJson Json            @map("response_json")

  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_interactions")
}

model UserSettings {
  id             String  @id @default(cuid())
  userId         String  @unique
  timezone       String  @default("UTC")
  ambientAudioOn Boolean @default(false) @map("ambient_audio_on")
  streakCount    Int     @default(0) @map("streak_count")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

enum SkillType {
  READING
  LISTENING
  SPEAKING
  WRITING
}

enum InteractionType {
  GRAMMAR_CHECK
  RECOMMENDATION
}